{
  "name": "dietcalibrator-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server exposing the DietCalibrator nutrition engine — Atwater calorie math, macro calibration, and daily food logging — as MCP tools, resources, and prompts.",
  "type": "module",
  "license": "MIT",
  "author": "Luke Dupuis",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nutrition",
    "macros",
    "diet"
  ],
  "bin": {
    "dietcalibrator-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "src/data"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "inspector": "npx @modelcontextprotocol/inspector tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
